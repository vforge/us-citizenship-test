{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y", "vitest", "import"],
  "categories": {
    "correctness": "error"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "serviceworker": true,
    "worker": true
  },
  "settings": {
    "react": {
      "version": "19.2.5"
    }
  },
  "ignorePatterns": ["dist", "test-results", "playwright-report"]
}
